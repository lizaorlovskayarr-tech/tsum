-- ========== РАСШИРЕННЫЙ СКАНИРОВАНИЕ ==========
local function AdvancedScan()
    -- ОЧИСТКА СТАРЫХ ESP
    for _, obj in pairs(ESP_Objects) do
        if obj and obj.Parent then obj:Destroy() end
    end
    ESP_Objects = {}
    
    local structure = FindGameStructure()
    local container = structure.ItemContainer
    
    -- ПОИСК ВСЕХ ПОДХОДЯЩИХ ОБЪЕКТОВ
    for _, v in pairs(container:GetDescendants()) do
        if v:IsA("BasePart") and v.Size.Magnitude > 1 then -- ФИЛЬТР МАЛЕНЬКИХ ОБЪЕКТОВ
            -- ОПРЕДЕЛЕНИЕ РЕДКОСТИ
            local rarity, color, spawnChance = GetItemRarityExtended(v)
            
            -- ПРОВЕРКА ФИЛЬТРОВ
            if not Filters[rarity] then continue end
            
            -- ПОЛУЧЕНИЕ ДОПОЛНИТЕЛЬНОЙ ИНФОРМАЦИИ
            local price = GetItemPrice(v)
            local itemType = "Unknown"
            
            -- ОПРЕДЕЛЕНИЕ ТИПА
            local name = v.Name:lower()
            if name:find("shirt") or name:find("фут") then itemType = "Shirt"
            elseif name:find("pants") or name:find("штаны") then itemType = "Pants"
            elseif name:find("hat") or name:find("шапк") then itemType = "Hat"
            elseif name:find("accessory") then itemType = "Accessory"
            elseif name:find("shoes") or name:find("обув") then itemType = "Shoes"
            end
            
            -- СОЗДАНИЕ ESP
            local esp = CreateAdvancedESP(v, rarity, color, spawnChance, price, itemType)
            if esp then table.insert(ESP_Objects, esp) end
            
            -- СОХРАНЕНИЕ ДАННЫХ ДЛЯ ГРАФИКА
            table.insert(ItemData, {
                Name = v.Name,
                Rarity = rarity,
                Price = price,
                Chance = spawnChance,
                Type = itemType,
                Position = v.Position
            })
        end
    end
end

