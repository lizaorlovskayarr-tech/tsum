-- ОПРЕДЕЛЕНИЕ РЕДКОСТИ
local function GetItemRarity(item)
    local name = item.Name:lower()
    local color = Color3.new(1, 1, 1)
    
    -- ПОИСК АТРИБУТОВ
    for _, child in pairs(item:GetChildren()) do
        if child:IsA("StringValue") and child.Name:lower() == "rarity" then
            local r = child.Value:lower()
            if r:find("myth") then return "Mythical", Color3.fromRGB(255, 50, 150), 0.1 end
            if r:find("legend") then return "Legendary", Color3.fromRGB(255, 200, 0), 0.5 end
            if r:find("epic") then return "Epic", Color3.fromRGB(170, 0, 255), 3.0 end
            if r:find("rare") then return "Rare", Color3.fromRGB(0, 150, 255), 10.0 end
            if r:find("uncom") then return "Uncommon", Color3.fromRGB(0, 255, 100), 30.0 end
            return "Common", Color3.fromRGB(200, 200, 200), 56.4
        end
    end
    
    -- ПО ЦВЕТУ (ЕСЛИ ЕСТЬ)
    if item:IsA("BasePart") and item.BrickColor then
        local c = item.BrickColor.Color
        if c.r > 0.9 and c.g > 0.7 and c.b < 0.1 then
            return "Legendary", Color3.fromRGB(255, 200, 0), 0.5
        elseif c.r > 0.6 and c.g < 0.1 and c.b > 0.8 then
            return "Epic", Color3.fromRGB(170, 0, 255), 3.0
        elseif c.r < 0.1 and c.g > 0.5 and c.b > 0.8 then
            return "Rare", Color3.fromRGB(0, 150, 255), 10.0
        elseif c.r < 0.1 and c.g > 0.7 and c.b < 0.2 then
            return "Uncommon", Color3.fromRGB(0, 255, 100), 30.0
        end
    end
    
    -- ПО НАЗВАНИЮ
    if name:find("legend") or name:find("gold") then
        return "Legendary", Color3.fromRGB(255, 200, 0), 0.5
    elseif name:find("epic") or name:find("purple") then
        return "Epic", Color3.fromRGB(170, 0, 255), 3.0
    elseif name:find("rare") or name:find("blue") then
        return "Rare", Color3.fromRGB(0, 150, 255), 10.0
    elseif name:find("uncommon") or name:find("green") then
        return "Uncommon", Color3.fromRGB(0, 255, 100), 30.0
    end
    
    return "Common", Color3.fromRGB(200, 200, 200), 56.4
end

-- ПОЛУЧЕНИЕ ЦЕНЫ
local function GetItemPrice(item)
    for _, child in pairs(item:GetChildren()) do
        if child:IsA("NumberValue") and child.Name:lower():find("price") then
            return child.Value
        end
        if child:IsA("StringValue") and child.Name:lower():find("price") then
            local val = tonumber(child.Value)
            if val then return val end
        end
        if child:IsA("TextLabel") or child:IsA("TextButton") then
            local text = child.Text
            local nums = text:match("(%d+)")
            if nums then return tonumber(nums) or 0 end
        end
    end
    return 0
end

-- СОЗДАНИЕ ESP
local function CreateESP(item, rarity, color, spawnChance, price)
    if not item or not item:IsA("BasePart") then return nil end
    
    -- ПРОВЕРКА ДИСТАНЦИИ
    local distance = (item.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
    if distance > Settings.MaxDistance then return nil end
    
    local billboard = Instance.new("BillboardGui")
    billboard.Adornee = item
    billboard.Size = UDim2.new(0, 320, 0, 70)
    billboard.StudsOffset = Vector3.new(0, 2.5, 0)
    billboard.AlwaysOnTop = true
    billboard.MaxDistance = Settings.MaxDistance
    billboard.Parent = item

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundTransparency = 0.2
    frame.BackgroundColor3 = Color3.fromRGB(10, 10, 30)
    frame.BorderSizePixel = 2
    frame.BorderColor3 = color
    frame.Parent = billboard

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = frame

    -- НАЗВАНИЕ
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, -10, 0.5, -5)
    nameLabel.Position = UDim2.new(0, 5, 0, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = item.Name .. " [" .. rarity .. "]"
    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameLabel.TextScaled = true
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.Parent = frame

    -- ВТОРАЯ СТРОКА (ШАНС ИЛИ ЦЕНА)
    local subText = ""
    if Settings.ShowChance then
        subText = subText .. "Шанс: " .. string.format("%.2f", spawnChance) .. "%"
    end
    if Settings.ShowPrice and price > 0 then
        if subText ~= "" then subText = subText .. " | " end
        subText = subText .. "Цена: " .. price .. "$"
    end
    if subText == "" then subText = "Редкость: " .. rarity end

    local infoLabel = Instance.new("TextLabel")
    infoLabel.Size = UDim2.new(1, -10, 0.4, -5)
    infoLabel.Position = UDim2.new(0, 5, 0.5, 2)
    infoLabel.BackgroundTransparency = 1
    infoLabel.Text = subText
    infoLabel.TextColor3 = color
    infoLabel.TextScaled = true
    infoLabel.Font = Enum.Font.Gotham
    infoLabel.TextXAlignment = Enum.TextXAlignment.Left
    infoLabel.Parent = frame

    return billboard
end

-- СКАНИРОВАНИЕ
local function ScanWorld()
    -- ОЧИСТКА
    for _, obj in pairs(ESP_Objects) do
        pcall(function() if obj and obj.Parent then obj:Destroy() end end)
    end
    ESP_Objects = {}
    ItemData = {}
    
    if not Settings.Enabled then return end
    
    local container = workspace:FindFirstChild("Items") or workspace:FindFirstChild("Clothing") or workspace
    
    for _, v in pairs(container:GetDescendants()) do
        if v:IsA("BasePart") and v.Size.Magnitude > 1 and v.Size.Magnitude < 50 then
            local rarity, color, chance = GetItemRarity(v)
            
            -- ФИЛЬТРАЦИЯ
            local filterPass = false
            if rarity == "Common" and Settings.FilterCommon then filterPass = true end
            if rarity == "Uncommon" and Settings.FilterUncommon then filterPass = true end
            if rarity == "Rare" and Settings.FilterRare then filterPass = true end
            if rarity == "Epic" and Settings.FilterEpic then filterPass = true end
            if rarity == "Legendary" and Settings.FilterLegendary then filterPass = true end
            if rarity == "Mythical" and Settings.FilterMythical then filterPass = true end
            
            if filterPass then
                local price = GetItemPrice(v)
                local esp = CreateESP(v, rarity, color, chance, price)
                if esp then 
                    table.insert(ESP_Objects, esp)
                    table.insert(ItemData, {
                        Name = v.Name,
                        Rarity = rarity,
                        Chance = chance,
                        Price = price,
                        Position = v.Position,
                        Object = v
                    })
                end
            end
        end
    end
    
    -- ОБНОВЛЕНИЕ СТАТИСТИКИ В GUI
    if GUI_Frame then
        local stats = GUI_Frame:FindFirstChild("StatsLabel")
        if stats then
            stats.Text = "Объектов: " .. #ESP_Objects .. " | Найдено: " .. #ItemData
        end
    end
end

