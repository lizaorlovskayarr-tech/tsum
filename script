-- ========== АВТОМАТИЧЕСКОЕ ОПРЕДЕЛЕНИЕ СТРУКТУРЫ ИГРЫ ==========
local function FindGameStructure()
    local structure = {
        ItemContainer = nil,
        ItemTypes = {},
        PriceLocations = {},
        RarityLocations = {}
    }
    
    -- ПОИСК КОНТЕЙНЕРА С ВЕЩАМИ
    local possibleContainers = {"Items", "Clothing", "Stand", "Display", "Shop", "Market", "Inventory"}
    for _, name in ipairs(possibleContainers) do
        local container = workspace:FindFirstChild(name)
        if container then
            structure.ItemContainer = container
            break
        end
    end
    
    -- ЕСЛИ НЕ НАШЛИ - СКАНИРУЕМ ВСЕ ОБЪЕКТЫ
    if not structure.ItemContainer then
        structure.ItemContainer = workspace
    end
    
    -- ОПРЕДЕЛЕНИЕ ТИПОВ ВЕЩЕЙ ПО НАЗВАНИЯМ
    for _, obj in pairs(structure.ItemContainer:GetDescendants()) do
        if obj:IsA("BasePart") then
            local name = obj.Name:lower()
            if name:find("shirt") or name:find("футболк") then
                table.insert(structure.ItemTypes, "Shirt")
            elseif name:find("pants") or name:find("штаны") or name:find("брюки") then
                table.insert(structure.ItemTypes, "Pants")
            elseif name:find("hat") or name:find("шапк") or name:find("кепк") then
                table.insert(structure.ItemTypes, "Hat")
            elseif name:find("accessory") or name:find("аксессуар") then
                table.insert(structure.ItemTypes, "Accessory")
            elseif name:find("shoes") or name:find("обув") or name:find("кросс") then
                table.insert(structure.ItemTypes, "Shoes")
            else
                table.insert(structure.ItemTypes, "Unknown")
            end
        end
    end
    
    return structure
end

-- ========== ФУНКЦИЯ ОПРЕДЕЛЕНИЯ РЕДКОСТИ (РАСШИРЕННАЯ) ==========
local function GetItemRarityExtended(item)
    local name = item.Name:lower()
    local parent = item.Parent
    local attributes = {}
    
    -- ПОИСК АТРИБУТОВ В ДОЧЕРНИХ ОБЪЕКТАХ
    for _, child in pairs(item:GetChildren()) do
        if child:IsA("StringValue") or child:IsA("NumberValue") or child:IsA("BoolValue") then
            attributes[child.Name] = child.Value
        end
    end
    
    -- АНАЛИЗ ЦВЕТА (ЕСЛИ ЕСТЬ)
    local color = Color3.new(1, 1, 1)
    if item:IsA("BasePart") and item.BrickColor then
        color = item.BrickColor.Color
    end
    
    -- ПРИОРИТЕТНАЯ ПРОВЕРКА ПО АТРИБУТАМ
    if attributes.Rarity then
        local rarity = tostring(attributes.Rarity):lower()
        if rarity:find("myth") or rarity:find("миф") then
            return "Mythical", Color3.fromRGB(255, 50, 150), 0.1
        elseif rarity:find("legend") or rarity:find("легенд") then
            return "Legendary", Color3.fromRGB(255, 200, 0), 0.5
        elseif rarity:find("epic") or rarity:find("эпик") then
            return "Epic", Color3.fromRGB(170, 0, 255), 3.0
        elseif rarity:find("rare") or rarity:find("редк") then
            return "Rare", Color3.fromRGB(0, 150, 255), 10.0
        elseif rarity:find("uncom") or rarity:find("необ") then
            return "Uncommon", Color3.fromRGB(0, 255, 100), 30.0
        else
            return "Common", Color3.fromRGB(200, 200, 200), 56.4
        end
    end
    
    -- АНАЛИЗ ПО ЦВЕТУ (ВТОРИЧНЫЙ)
    if color.r > 0.9 and color.g > 0.7 and color.b < 0.1 then
        return "Legendary", Color3.fromRGB(255, 200, 0), 0.5
    elseif color.r > 0.6 and color.g < 0.1 and color.b > 0.8 then
        return "Epic", Color3.fromRGB(170, 0, 255), 3.0
    elseif color.r < 0.1 and color.g > 0.5 and color.b > 0.8 then
        return "Rare", Color3.fromRGB(0, 150, 255), 10.0
    elseif color.r < 0.1 and color.g > 0.7 and color.b < 0.2 then
        return "Uncommon", Color3.fromRGB(0, 255, 100), 30.0
    else
        return "Common", Color3.fromRGB(200, 200, 200), 56.4
    end
end

-- ========== ФУНКЦИЯ ПОЛУЧЕНИЯ ЦЕНЫ ==========
local function GetItemPrice(item)
    local price = 0
    
    -- ПОИСК В ДОЧЕРНИХ ОБЪЕКТАХ
    for _, child in pairs(item:GetChildren()) do
        if child:IsA("NumberValue") and (child.Name:lower():find("price") or child.Name:lower():find("cost") or child.Name:lower():find("цен")) then
            price = child.Value
            break
        end
    end
    
    -- ПОИСК В ТЕКСТОВЫХ МЕТКАХ
    for _, child in pairs(item:GetChildren()) do
        if child:IsA("TextLabel") or child:IsA("TextButton") then
            local text = child.Text
            local numbers = text:match("(%d+)")
            if numbers then
                price = tonumber(numbers) or 0
                break
            end
        end
    end
    
    return price
end

