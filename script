-- ОПРЕДЕЛЕНИЕ РЕДКОСТИ (УЛУЧШЕННОЕ)
local function GetItemRarity(item)
    local name = item.Name:lower()
    local attributes = {}
    
    for _, child in pairs(item:GetChildren()) do
        if child:IsA("StringValue") or child:IsA("NumberValue") then
            attributes[child.Name:lower()] = child.Value
        end
    end
    
    -- ПРИОРИТЕТ: АТРИБУТЫ
    if attributes.rarity then
        local r = tostring(attributes.rarity):lower()
        if r:find("myth") then return "Mythical", Color3.fromRGB(255, 50, 150), 0.1
        elseif r:find("legend") then return "Legendary", Color3.fromRGB(255, 200, 0), 0.5
        elseif r:find("epic") then return "Epic", Color3.fromRGB(170, 0, 255), 3.0
        elseif r:find("rare") then return "Rare", Color3.fromRGB(0, 150, 255), 10.0
        elseif r:find("uncom") then return "Uncommon", Color3.fromRGB(0, 255, 100), 30.0
        else return "Common", Color3.fromRGB(200, 200, 200), 56.4 end
    end
    
    -- АНАЛИЗ ЦВЕТА
    if item:IsA("BasePart") and item.BrickColor then
        local c = item.BrickColor.Color
        if c.r > 0.9 and c.g > 0.7 and c.b < 0.1 then
            return "Legendary", Color3.fromRGB(255, 200, 0), 0.5
        elseif c.r > 0.6 and c.g < 0.1 and c.b > 0.8 then
            return "Epic", Color3.fromRGB(170, 0, 255), 3.0
        elseif c.r < 0.1 and c.g > 0.5 and c.b > 0.8 then
            return "Rare", Color3.fromRGB(0, 150, 255), 10.0
        elseif c.r < 0.1 and c.g > 0.7 and c.b < 0.2 then
            return "Uncommon", Color3.fromRGB(0, 255, 100), 30.0
        end
    end
    
    return "Common", Color3.fromRGB(200, 200, 200), 56.4
end

-- СОЗДАНИЕ ESP МЕТКИ
local function CreateESP(item, rarity, color, spawnChance)
    if not item or not item:IsA("BasePart") then return end
    
    local billboard = Instance.new("BillboardGui")
    billboard.Adornee = item
    billboard.Size = UDim2.new(0, 300, 0, 60)
    billboard.StudsOffset = Vector3.new(0, 2.5, 0)
    billboard.AlwaysOnTop = true
    billboard.MaxDistance = Settings.MaxDistance
    billboard.Parent = item

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundTransparency = 0.3
    frame.BackgroundColor3 = Color3.fromRGB(10, 10, 25)
    frame.BorderSizePixel = 2
    frame.BorderColor3 = color
    frame.Parent = billboard

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = frame

    -- НАЗВАНИЕ
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, -10, 0.5, -5)
    nameLabel.Position = UDim2.new(0, 5, 0, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = item.Name .. " [" .. rarity .. "]"
    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameLabel.TextScaled = true
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.Parent = frame

    -- ШАНС (ЕСЛИ ВКЛЮЧЕН)
    if Settings.ShowChance then
        local chanceLabel = Instance.new("TextLabel")
        chanceLabel.Size = UDim2.new(1, -10, 0.4, -5)
        chanceLabel.Position = UDim2.new(0, 5, 0.5, 2)
        chanceLabel.BackgroundTransparency = 1
        chanceLabel.Text = "Шанс: " .. string.format("%.2f", spawnChance) .. "%"
        chanceLabel.TextColor3 = color
        chanceLabel.TextScaled = true
        chanceLabel.Font = Enum.Font.Gotham
        chanceLabel.TextXAlignment = Enum.TextXAlignment.Left
        chanceLabel.Parent = frame
    end

    return billboard
end

-- СКАНИРОВАНИЕ МИРА
local function ScanWorld()
    -- ОЧИСТКА
    for _, obj in pairs(ESP_Objects) do
        if obj and obj.Parent then obj:Destroy() end
    end
    ESP_Objects = {}
    ItemData = {}
    
    if not Settings.Enabled then return end
    
    local container = workspace:FindFirstChild("Items") or workspace
    
    for _, v in pairs(container:GetDescendants()) do
        if v:IsA("BasePart") and v.Size.Magnitude > 1 then
            local rarity, color, chance = GetItemRarity(v)
            
            -- ФИЛЬТРАЦИЯ
            local filterPass = false
            if rarity == "Common" and Settings.FilterCommon then filterPass = true end
            if rarity == "Uncommon" and Settings.FilterUncommon then filterPass = true end
            if rarity == "Rare" and Settings.FilterRare then filterPass = true end
            if rarity == "Epic" and Settings.FilterEpic then filterPass = true end
            if rarity == "Legendary" and Settings.FilterLegendary then filterPass = true end
            if rarity == "Mythical" and Settings.FilterMythical then filterPass = true end
            
            if filterPass then
                local esp = CreateESP(v, rarity, color, chance)
                if esp then table.insert(ESP_Objects, esp) end
                table.insert(ItemData, {Name = v.Name, Rarity = rarity, Chance = chance, Position = v.Position})
            end
        end
    end
end

